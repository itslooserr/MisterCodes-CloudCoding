<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Glowing outer minimal professional golden ring -->
    <path
        android:fillColor="#00000000"
        android:pathData="M 54,54 m -32,0 a 32,32 0 1,0 64,0 a 32,32 0 1,0 -64,0"
        android:strokeWidth="3.5">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="22"
                android:startY="22"
                android:endX="86"
                android:endY="86"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFF43C" />
                <item android:offset="0.5" android:color="#FFD700" />
                <item android:offset="1.0" android:color="#FF8F00" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Stylized '<' Bracket in pure premium Gold gradient -->
    <path
        android:pathData="M 40,40 L 28,54 L 40,68"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="28"
                android:startY="40"
                android:endX="40"
                android:endY="68"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFF43C" />
                <item android:offset="1.0" android:color="#FFD700" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Stylized '>' Bracket in pure premium Gold gradient -->
    <path
        android:pathData="M 68,40 L 80,54 L 68,68"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="68"
                android:startY="40"
                android:endX="80"
                android:endY="68"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFD700" />
                <item android:offset="1.0" android:color="#FF8F00" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Central forward slash '/' in Amber gradient -->
    <path
        android:pathData="M 57,36 L 51,72"
        android:strokeWidth="5.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="51"
                android:startY="36"
                android:endX="57"
                android:endY="72"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFF43C" />
                <item android:offset="1.0" android:color="#FF8F00" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
